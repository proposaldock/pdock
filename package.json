{
  "name": "proposaldock",
  "version": "1.0.0",
  "description": "A local MVP SaaS workflow for RFP and proposal analysis.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:generate:postgres": "prisma generate --schema prisma/schema.prisma",
    "db:push:postgres": "prisma db push --schema prisma/schema.prisma",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:push:sqlite": "prisma db push --schema prisma/schema.sqlite.prisma",
    "db:migrate:sqlite-to-postgres": "npm run db:generate && npm run db:generate:sqlite && node scripts/migrate-sqlite-to-postgres.mjs",
    "launch:preflight": "node scripts/launch-preflight.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^6.16.2",
    "@vercel/blob": "^2.3.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "dotenv": "^17.4.1",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.3",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.16.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
